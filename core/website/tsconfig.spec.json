{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../dist/out-tsc",
        "types": ["vitest/importMeta", "vite/client", "node", "vitest"]
    },
    "include": [
        "vite.config.ts",
        "vite.config.mts",
        "vitest.config.ts",
        "vitest.config.mts",
        "app/**/*.test.ts",
        "app/**/*.spec.ts",
        "app/**/*.test.tsx",
        "app/**/*.spec.tsx",
        "app/**/*.test.js",
        "app/**/*.spec.js",
        "app/**/*.test.jsx",
        "app/**/*.spec.jsx",
        "app/**/*.d.ts"
    ]
}
