{
    "include": ["env.d.ts", "worker-configuration.d.ts", "**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
    "compilerOptions": {
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        // Cloudflare runtime types now come from the ambient
        // worker-configuration.d.ts generated by `wrangler types` (Nx
        // `setup` target), so no @cloudflare/workers-types package is needed.
        "types": [],
        "isolatedModules": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "target": "ES2022",
        "strict": true,
        "allowJs": true,
        "pretty": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "~/*": ["./app/*"],
            // Conference manifest indirection — see /libs/conference-config/src/manifest.ts.
            // Fork override: points at the fork's /conference/ folder (two
            // levels up from core/website/). ddd-core standalone uses
            // ../conference-stub/ — restore that path if syncing back upstream.
            "@conference/manifest": ["../../conference/manifest"],
            "@conference/build-manifest": ["../../conference/build-manifest"],
            "@conference/*": ["../../conference/*"]
        },
        "noEmit": true,
        "rootDirs": [".", "./.react-router/types"]
    }
}
