strict-peer-dependencies=false
auto-install-peers=true

# Supply-chain protection: refuse to install package versions younger than this.
# Recent npm/pnpm compromises were typically detected and yanked within hours,
# so a 3-day cooldown catches most of them. Bump higher (e.g. 7d) for more safety
# at the cost of slower access to legitimate fixes. Override per-install with
# --minimum-release-age=0, or exclude specific packages via
# `minimum-release-age-exclude` if a vetted dep is blocking a CI bump.
minimum-release-age=4320
