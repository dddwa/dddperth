{
    "extends": "../../tsconfig.base.json",
    "include": ["src/**/*.ts"],
    "compilerOptions": {
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "strict": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "rootDir": "src"
    }
}
