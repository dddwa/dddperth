{
    "extends": "../tsconfig.base.json",
    "include": ["**/*.ts", "manifest.ts"],
    "exclude": ["node_modules"],
    "compilerOptions": {
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "strict": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "types": ["node"]
    }
}
